NEO4J_URI="bolt://localhost:7688"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your-password"

# ── LLM Backend ────────────────────────────────────────────────────────────
# Switch between: "proxy" (gpu3 Ollama), "local" (local Ollama), "openrouter"
LLM_BACKEND=openrouter

# ── Ollama Proxy (gpu3) ────────────────────────────────────────────────────
OLLAMA_PROXY_URL="your-token"
OLLAMA_PROXY_TOKEN="your-token"

# Ollama model used when LLM_BACKEND=proxy or local
LLM_MODEL=gemma4:latest

# ── OpenRouter ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY="your-token"
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_MODEL=google/gemini-3-flash-preview

# ── Embedding (always Ollama proxy unless local mode) ──────────────────────
EMBEDDING_MODEL=qwen3-embedding:8b
INTENT_SEARCH_THRESHOLD=0.0
