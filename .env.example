OLLAMA_PROXY_TOKEN="your-token"

# The public URL of the proxy server (used by client scripts like llm_review.py)
OLLAMA_PROXY_URL="your-ollama-url"

# ======================================================================
# Local Settings (Optional)
# ======================================================================

# The local Ollama instance URL that the proxy server forwards requests to.
# This is also used by client scripts if they run in --mode local.
# OLLAMA_BASE_URL=http://localhost:11434